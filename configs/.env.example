# 闲鱼自动回复系统 - 环境变量配置示例
# 复制此文件为 .env 并根据需要修改配置
# 注意：此文件仅作为配置示例，请勿提交包含真实敏感信息的文件到版本控制

# ================================
# 闲鱼API配置
# ================================

# 应用标识（闲鱼API App Key）- 敏感信息，勿泄露
XIANYU_APP_KEY=your-app-key-here

# 设备标识（用于设备指纹）
XIANYU_DEVICE_ID=000000000000000

# UMID标识（用户监控ID）
XIANYU_UMID=1000

# ================================
# JWT认证配置
# ================================

# JWT密钥 - 必须修改为强随机字符串
XIANYU_JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production

# ================================
# Cookie加密配置
# ================================

# Cookie加密密钥（推荐）- 使用以下命令生成：
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# 将生成的密钥填入下方
COOKIE_ENCRYPTION_KEY=

# 或者使用密码派生密钥（备选方案）
# COOKIE_ENCRYPTION_PASSWORD=your-strong-password-here
# COOKIE_ENCRYPTION_SALT=xianyu-auto-reply-salt

# ================================
# 应用配置
# ================================

# API文档启用/禁用 (true/false)
XIANYU_ENABLE_DOCS=true

# 调试模式 (true/false) - 生产环境应设为 false
XIANYU_DEBUG=false
