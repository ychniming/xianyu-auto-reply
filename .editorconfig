root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.py]
indent_size = 4
max_line_length = 120

[*.{yml,yaml}]
indent_size = 2

[*.{json,toml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false
max_line_length = off

[*.{js,jsx,ts,tsx}]
indent_size = 2

[*.css]
indent_size = 2

[*.html]
indent_size = 2

[Makefile]
indent_style = tab

[*.sh]
indent_size = 2
end_of_line = lf

[Dockerfile*]
indent_size = 2

[.dockerignore]
indent_size = 2
